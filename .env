# ═══════════════════════════════════════════════════════════════
#  Technodysis Meeting Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Microsoft Azure / Graph API ────────────────────────────────
# App registration in Azure AD with CallRecords.Read.All permission
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=0
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Teams Webhook ───────────────────────────────────────────────
# Shared secret sent in clientState field of Graph notifications
TEAMS_WEBHOOK_SECRET=replace-with-a-long-random-string

# Public URL where Graph API will send webhook POSTs
# Use ngrok for local dev: ngrok http 8000
WEBHOOK_BASE_URL=https://your-domain.ngrok.io

# ── Database ────────────────────────────────────────────────────
# asyncpg driver for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://meetuser:meetpass@localhost:5432/meetingdb

# ── MinIO (S3-compatible local object storage) ──────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=meeting-recordings

# ── SMTP Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@technodysis.com

# Email address to receive failure alerts
ADMIN_EMAIL=admin@technodysis.com

# ── Ollama LLM ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model used for meeting extraction (llama3.2:3b is fast; llama3:8b is more accurate)
MEETING_LLM_MODEL=llama3.2:3b

# Timeout in seconds for LLM extraction call
MEETING_LLM_TIMEOUT=120

# ── Whisper Transcription ───────────────────────────────────────
# Model size: tiny, base, small, medium, large-v2
WHISPER_MODEL_SIZE=base

# Device: cpu or cuda
WHISPER_DEVICE=cuda

# Language hint (leave blank for auto-detect)
WHISPER_LANGUAGE=en

# HuggingFace token required for pyannote diarization in whisperx
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Jira Integration (optional) ─────────────────────────────────
# Set to true to auto-create Jira tickets from action items
JIRA_ENABLED=false

JIRA_URL=https://your-company.atlassian.net
JIRA_USER=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=MEET

# ── Existing Voice Agent Settings (unchanged) ───────────────────
STT_MODEL_NAME=base
LLM_MODEL=llama3.2:3b
TTS_VOICE=en-IN-NeerjaNeural
TTS_PROVIDER=edge

# ── Memgraph Knowledge Graph (optional) ─────────────────────────
# Set MEMGRAPH_ENABLED=true to activate the graph intelligence layer.
# Memgraph runs in Docker on port 7687 — no extra credentials needed by default.
MEMGRAPH_ENABLED=false
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# ── NLP Intelligence ─────────────────────────────────────────────
# Minimum documents per topic cluster for BERTopic (lower = more topics)
BERTOPIC_MIN_TOPIC_SIZE=3

# Cosine similarity threshold for entity deduplication (0.0–1.0)
# Higher = stricter matching; lower = more aggressive merging
ENTITY_RESOLVER_THRESHOLD=0.82
